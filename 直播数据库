赛事表
CREATE TABLE `match_info` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    `match_id` VARCHAR(64) NOT NULL COMMENT '第三方比赛ID',
    `sport_type` VARCHAR(32) COMMENT '体育类型 football/basketball',
    `league_name` VARCHAR(128) COMMENT '联赛名称',
    `home_team` VARCHAR(128) COMMENT '主队',
    `away_team` VARCHAR(128) COMMENT '客队',
    `match_status` VARCHAR(32) COMMENT '比赛状态',
    `match_time` DATETIME COMMENT '比赛时间',
    `home_score` INT DEFAULT 0 COMMENT '主队比分',
    `away_score` INT DEFAULT 0 COMMENT '客队比分',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP,
    KEY `idx_match_time` (`match_time`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='比赛信息表';

直播源表
CREATE TABLE `live_stream_source` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    `match_id` BIGINT NOT NULL COMMENT '比赛ID',
    `source_name` VARCHAR(128) COMMENT '源名称',
    `source_url` TEXT COMMENT '播放地址',
    `source_type` VARCHAR(32) COMMENT 'hls/flv/rtmp',
    `delay_seconds` INT DEFAULT 0 COMMENT '延迟秒数',
    `priority_level` INT DEFAULT 1 COMMENT '优先级',
    `source_status` VARCHAR(32) COMMENT '状态',
    `last_check_time` DATETIME COMMENT '最后检测时间',
    `available_rate` DECIMAL(5,2) DEFAULT 0 COMMENT '可用率',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP,
    KEY `idx_match_id` (`match_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='直播源表';

直播间表
CREATE TABLE `live_room` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    `match_id` BIGINT NOT NULL COMMENT '比赛ID',
    `room_name` VARCHAR(128) COMMENT '直播间名称',
    `cover_image` VARCHAR(512) COMMENT '封面图',
    `room_status` VARCHAR(32) COMMENT '房间状态',
    `online_count` INT DEFAULT 0 COMMENT '在线人数',
    `main_source_id` BIGINT COMMENT '主直播源',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP,
    KEY `idx_match_id` (`match_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='直播间表';


主播表
CREATE TABLE `anchor_info` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主播ID',
    `anchor_name` VARCHAR(128) COMMENT '主播名称',
    `avatar` VARCHAR(512) COMMENT '头像',
    `intro` VARCHAR(512) COMMENT '简介',
    `status` VARCHAR(32) COMMENT '状态',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='主播表';

直播间主播关联表
CREATE TABLE `live_room_anchor` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    `room_id` BIGINT NOT NULL COMMENT '直播间ID',
    `anchor_id` BIGINT NOT NULL COMMENT '主播ID',
    `sort_order` INT DEFAULT 0 COMMENT '排序',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP,
    KEY `idx_room_id` (`room_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='直播间主播关联表';

聊天室消息表

CREATE TABLE `chat_message` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '消息ID',
    `room_id` BIGINT NOT NULL COMMENT '直播间ID',
    `user_id` BIGINT COMMENT '用户ID',
    `username` VARCHAR(128) COMMENT '用户名',
    `message_type` VARCHAR(32) COMMENT '消息类型',
    `content` TEXT COMMENT '消息内容',
    `send_time` DATETIME DEFAULT CURRENT_TIMESTAMP,
    KEY `idx_room_id` (`room_id`),
    KEY `idx_send_time` (`send_time`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='聊天室消息表';


广告配置表
CREATE TABLE `live_ad_config` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '广告ID',
    `ad_name` VARCHAR(128) COMMENT '广告名称',
    `ad_type` VARCHAR(32) COMMENT '广告类型',
    `ad_position` VARCHAR(32) COMMENT '广告位置',
    `image_url` VARCHAR(512) COMMENT '图片地址',
    `redirect_url` VARCHAR(512) COMMENT '跳转地址',
    `start_time` DATETIME COMMENT '开始时间',
    `end_time` DATETIME COMMENT '结束时间',
    `enabled` TINYINT DEFAULT 1 COMMENT '是否启用',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='直播广告配置表';


直播间广告关联表
CREATE TABLE `live_room_ad` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    `room_id` BIGINT NOT NULL COMMENT '直播间ID',
    `ad_id` BIGINT NOT NULL COMMENT '广告ID',
    `sort_order` INT DEFAULT 0 COMMENT '排序',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='直播间广告关联表';

直播源巡检表
CREATE TABLE `stream_check_record` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    `source_id` BIGINT NOT NULL COMMENT '直播源ID',
    `check_status` VARCHAR(32) COMMENT '检测状态',
    `response_time_ms` BIGINT COMMENT '响应时间',
    `error_msg` VARCHAR(512) COMMENT '错误信息',
    `check_time` DATETIME DEFAULT CURRENT_TIMESTAMP,
    KEY `idx_source_id` (`source_id`),
    KEY `idx_check_time` (`check_time`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='直播源巡检记录表';


直播源切换记录
CREATE TABLE `source_switch_log` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    `room_id` BIGINT NOT NULL COMMENT '直播间ID',
    `old_source_id` BIGINT COMMENT '旧源',
    `new_source_id` BIGINT COMMENT '新源',
    `switch_reason` VARCHAR(512) COMMENT '切换原因',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='直播源切换记录表';


比赛事件表
CREATE TABLE `match_event` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',
    `match_id` BIGINT NOT NULL COMMENT '比赛ID',
    `event_type` VARCHAR(32) COMMENT '事件类型',
    `event_time` VARCHAR(32) COMMENT '比赛时间',
    `team_name` VARCHAR(128) COMMENT '球队',
    `player_name` VARCHAR(128) COMMENT '球员',
    `description` VARCHAR(512) COMMENT '事件描述',
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='比赛事件表';


用户基础表
CREATE TABLE `user_info` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '用户ID',    
    `user_no` VARCHAR(64) NOT NULL COMMENT '用户编号',    
    `username` VARCHAR(128) NOT NULL COMMENT '用户名',    
    `nickname` VARCHAR(128) DEFAULT NULL COMMENT '昵称',    
    `avatar` VARCHAR(512) DEFAULT NULL COMMENT '头像',    
    `gender` TINYINT DEFAULT 0 COMMENT '性别 0未知 1男 2女',    
    `country_code` VARCHAR(16) DEFAULT NULL COMMENT '国家编码',    
    `phone` VARCHAR(32) DEFAULT NULL COMMENT '手机号',    
    `email` VARCHAR(128) DEFAULT NULL COMMENT '邮箱',    
    `password_hash` VARCHAR(255) NOT NULL COMMENT '密码HASH',    
    `salt` VARCHAR(64) DEFAULT NULL COMMENT '密码盐值',    
    `user_level` INT DEFAULT 1 COMMENT '用户等级',    
    `vip_level` INT DEFAULT 0 COMMENT 'VIP等级',    
    `user_status` VARCHAR(32) DEFAULT 'normal' COMMENT '用户状态(normal/banned/muted)',    
    `last_login_ip` VARCHAR(64) DEFAULT NULL COMMENT '最后登录IP',    
    `last_login_time` DATETIME DEFAULT NULL COMMENT '最后登录时间',    
    `register_ip` VARCHAR(64) DEFAULT NULL COMMENT '注册IP',    
    `register_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '注册时间',    
    `online_status` TINYINT DEFAULT 0 COMMENT '在线状态',    
    `remark` VARCHAR(512) DEFAULT NULL COMMENT '备注',    
    PRIMARY KEY (`id`),    
    UNIQUE KEY `uk_user_no` (`user_no`),    
    UNIQUE KEY `uk_username` (`username`),    
    KEY `idx_register_time` (`register_time`),    
    KEY `idx_last_login_time` (`last_login_time`)    
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='用户基础信息表';

用户设备表

CREATE TABLE `user_device` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',    
    `user_id` BIGINT NOT NULL COMMENT '用户ID',    
    `device_id` VARCHAR(128) DEFAULT NULL COMMENT '设备ID',    
    `device_name` VARCHAR(128) DEFAULT NULL COMMENT '设备名称',    
    `os_type` VARCHAR(32) DEFAULT NULL COMMENT '系统类型',    
    `app_version` VARCHAR(32) DEFAULT NULL COMMENT 'APP版本',    
    `ip` VARCHAR(64) DEFAULT NULL COMMENT 'IP地址',    
    `country` VARCHAR(64) DEFAULT NULL COMMENT '国家',    
    `city` VARCHAR(64) DEFAULT NULL COMMENT '城市',    
    `last_active_time` DATETIME DEFAULT NULL COMMENT '最后活跃时间',    
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',    
    PRIMARY KEY (`id`),    
    KEY `idx_user_id` (`user_id`)    
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='用户设备表';


聊天室禁言表
CREATE TABLE `user_mute_record` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',    
    `user_id` BIGINT NOT NULL COMMENT '用户ID',    
    `room_id` BIGINT DEFAULT NULL COMMENT '直播间ID',    
    `mute_reason` VARCHAR(512) DEFAULT NULL COMMENT '禁言原因',    
    `start_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '开始时间',    
    `end_time` DATETIME DEFAULT NULL COMMENT '结束时间',    
    `operator_name` VARCHAR(128) DEFAULT NULL COMMENT '操作人',    
    PRIMARY KEY (`id`),    
    KEY `idx_user_id` (`user_id`)    
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='用户禁言记录表';


用户关注主播表

CREATE TABLE `user_follow_anchor` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',    
    `user_id` BIGINT NOT NULL COMMENT '用户ID',    
    `anchor_id` BIGINT NOT NULL COMMENT '主播ID',    
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '关注时间',    
    PRIMARY KEY (`id`),    
    UNIQUE KEY `uk_user_anchor` (`user_id`, `anchor_id`)    
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='用户关注主播表';

用户收藏比赛表
CREATE TABLE `user_favorite_match` (
    `id` BIGINT PRIMARY KEY AUTO_INCREMENT COMMENT '主键ID',    
    `user_id` BIGINT NOT NULL COMMENT '用户ID',    
    `match_id` BIGINT NOT NULL COMMENT '比赛ID',    
    `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '收藏时间',    
    PRIMARY KEY (`id`),    
    UNIQUE KEY `uk_user_match` (`user_id`, `match_id`)    
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='用户收藏比赛表';



